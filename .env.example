# =============================================================================
# AI 智能体平台 — 环境变量模板
# =============================================================================
# 复制此文件为 .env 并根据需要修改：
#   cp .env.example .env
# 注意：.env 已在 .gitignore 中，不会提交到仓库。
# =============================================================================

# ─── OpenClaw Gateway ──────────────────────────────────────────────────────
OPENCLAW_GATEWAY_PORT=18789

# Gateway 认证 Token（留空自动生成，建议手动设置固定值）
# 生成: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ─── 大模型 API Key（至少设置一个）──────────────────────────────────────
DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ─── LibreChat 多用户聊天界面 ────────────────────────────────────────────
LIBRECHAT_PORT=3080

# 注册控制
ALLOW_REGISTRATION=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true
ALLOW_EMAIL_LOGIN=true

# JWT 密钥（生产环境务必修改，32 字节 hex）
# 生成: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# 搜索索引密钥（生产环境务必修改）
# 生成: openssl rand -hex 32
MEILI_MASTER_KEY=

# ─── Open WebUI 多用户聊天界面 ───────────────────────────────────────────
OPENWEBUI_PORT=3090

# OpenClaw Gateway 作为 OpenAI-compatible 后端
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://openclaw-gateway:18789/v1
OPENAI_API_KEY=${OPENCLAW_GATEWAY_TOKEN}

# ─── 通用 ──────────────────────────────────────────────────────────────────
TZ=Asia/Shanghai
